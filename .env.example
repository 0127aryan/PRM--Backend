# Copy this file to `.env` and set every value for your machine.
# The application does not use hardcoded defaults — missing keys fail at startup.
# Data is created via the PRM admin UI (no seed scripts).

# --- Application ---
NODE_ENV=development
PORT=3004
API_HOST=127.0.0.1
API_PREFIX=api
APP_NAME=prm-api
FRONTEND_URL=http://localhost:3001

# --- CORS (comma-separated lists) ---
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# --- Supabase PostgreSQL ---
DB_HOST=aws-1-ap-northeast-1.pooler.supabase.com
DB_PORT=5432
DB_USERNAME=postgres.oruobmplckdxlbddlwwr
DB_PASSWORD=your-supabase-db-password
DB_DATABASE=postgres
DB_SSL=true
# Optional connection string (overrides DB_HOST/PORT/USER/PASSWORD/DATABASE):
# DATABASE_URL=postgresql://postgres.oruobmplckdxlbddlwwr:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

DB_MIGRATIONS_TABLE=typeorm_migrations
TYPEORM_LOGGING=false

# --- JWT (Phase 2+; min 32 chars) ---
JWT_ACCESS_SECRET=replace-with-at-least-32-char-access-secret
JWT_REFRESH_SECRET=replace-with-at-least-32-char-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# --- Auth cookies ---
COOKIE_ACCESS_NAME=prm_access
COOKIE_REFRESH_NAME=prm_refresh
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
PASSWORD_SETUP_TOKEN_EXPIRES_HOURS=72

# --- Scheduler ---
SCHEDULER_ENABLED=true
SCHEDULER_CRON=0 * * * *

# --- Swagger (UI at /{API_PREFIX}/{SWAGGER_PATH}, e.g. /api/docs) ---
SWAGGER_TITLE=XYZ PRM API
SWAGGER_DESCRIPTION=Project and Resource Management — BRD V3
SWAGGER_VERSION=1.0
SWAGGER_PATH=docs

# --- LLM (Gemma / Groq / Gemini — OpenAI-compatible host or provider defaults) ---
# Required when matching_mode=llm in Admin settings.
LLM_HOST=https://api.groq.com/openai/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gemma2-9b-it
